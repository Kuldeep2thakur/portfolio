rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Projects - public read, authenticated write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Skills - public read, authenticated write
    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Certificates - public read, authenticated write
    match /certificates/{certId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Profile - public read, authenticated write
    match /profile/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contacts - anyone can submit, only authenticated users can read/delete
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
